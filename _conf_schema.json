{
  "steam_api_key": {
    "description": "Steam Web API Key",
    "type": "string",
    "default": "",
    "required": true
  },
  "napcat_http_url": {
    "description": "NapCat HTTP API 地址",
    "type": "string",
    "default": "http://127.0.0.1:6099",
    "required": true
  },
  "napcat_token": {
    "description": "NapCat access_token（没设鉴权就留空）",
    "type": "string",
    "default": ""
  },
  "monitored_groups": {
    "description": "监控加群申请的群号列表（空=全部群）",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": []
  },
  "notify_group_id": {
    "description": "审核卡片发到哪个群（留空=发到申请的群）",
    "type": "string",
    "default": ""
  },
  "auto_reject_vac": {
    "description": "自动拒绝有VAC封禁的玩家",
    "type": "bool",
    "default": false
  },
  "min_steam_level": {
    "description": "最低Steam等级要求（0=不限）",
    "type": "int",
    "default": 0
  },
  "min_games_count": {
    "description": "最低游戏数量要求（0=不限）",
    "type": "int",
    "default": 0
  },
  "required_game_appids": {
    "description": "必须拥有的游戏AppID列表",
    "type": "list",
    "items": {
      "type": "int"
    },
    "default": []
  },
  "poll_interval": {
    "description": "轮询加群请求间隔秒数",
    "type": "int",
    "default": 10
  },
  "card_expire_minutes": {
    "description": "审核卡片过期时间（分钟）",
    "type": "int",
    "default": 1440
  }
}
